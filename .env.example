# ── Login Option 1: Username & Password ──
GITHUB_USERNAME=
GITHUB_PASSWORD=

# ── Login Option 2: Cookie (from browser DevTools) ──
# Copy from: DevTools > Application > Cookies > github.com
# Format: user_session=xxx; __Host-user_session_same_site=xxx; _gh_sess=xxx; logged_in=yes
GITHUB_COOKIE=

# ── Face Studio API (optional, for AI-generated photos) ──
# Get your API key from: https://facestud.io/
# Uses GET method to generate random face photos
# Leave blank to use GitHub avatar instead
FACESTUDIO_API_KEY=

# ── Education Benefits (Step 5) ──
GITHUB_EDU_SCHOOL_NAME=KMD COLLEGE
GITHUB_EDU_SCHOOL_EMAIL=
GITHUB_EDU_LATITUDE=16.8661
GITHUB_EDU_LONGITUDE=96.1951
#GITHUB_EDU_PROOF_TYPE=2. Dated official/unofficial transcript
